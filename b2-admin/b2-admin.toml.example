log = "b2_admin=debug"
web_addr = "0.0.0.0:9527"

[[b2s]]
name = "存储桶1"
endpoint = "s3.eu-central-003.backblazeb2.com"
key_id = "<key_id>"
app_id = "<app_id>"
bucket_name = "<bucket_name>"

[[b2s]]
name = "存储桶2"
endpoint = "s3.us-west-004.backblazeb2.com"
key_id = "<key_id>"
app_id = "<app_id>"
bucket_name = "<bucket_name>"

[jwt]
secret = "<jwt_secret>"
expire = 3600

[b2_action]
root_tmp_dir = "/tmp/b2-admin"

[b2_action.upload]
max_size = 10485760
tmp_dir = "upload"
tmp_part_dir = "upload/parts"

[b2_action.download]
max_size = 10485760
tmp_dir = "download"

[b2_action.preview]
text_max_size = 1048576
image_max_size = 1048576
tmp_dir = "preview"

[admin]
email = "team@mail.axum.eu.org"
password = "foobar"

[turnstile]
site_key = '1x00000000000000000000AA'
secret_key = '1x0000000000000000000000000000000AA'
timeout = 10
